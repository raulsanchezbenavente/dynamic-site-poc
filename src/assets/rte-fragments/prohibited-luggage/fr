      alt="" />
  </div>
  <div class="dangerous-good_title-wrapper">
    <h2 class="dangerous-good_title">Interdit dans tout type de bagage</h2>
  </div>
  <div class="dangerous-good_content dangerous-good_content--restricted">
    <div class="dangerous-good_block-1--restricted">
      <ul class="dangerous-good_list ds-list_list">
        <li class="dangerous-good_list-item dangerous-good_list-item--restricted">Solides inflammables</li>
