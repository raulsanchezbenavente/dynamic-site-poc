{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "dynamic-site": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/dynamic-site",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js", "@angular/localize/init"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "stylePreprocessorOptions": {
              "includePaths": ["src/app/modules"]
            },
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "assets"
              }
            ],
            "styles": [
              "./src/app/modules/design-system/assets/styles/core-theme.css",
              "./src/app/modules/design-system/assets/styles/common.css",
              "./src/app/modules/design-system/assets/ui_plus/icons/webfonts/iconfonts-styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1500kB",
                  "maximumError": "2400kB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "9kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "bypass": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.bypass.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "dynamic-site:build:production"
            },
            "development": {
              "buildTarget": "dynamic-site:build:development"
            },
            "bypass": {
              "buildTarget": "dynamic-site:build:bypass"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "@angular/localize/init", "zone.js/testing"],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "stylePreprocessorOptions": {
              "includePaths": ["src/app/modules"]
            },
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "./src/app/modules/design-system/assets/styles/core-theme.css",
              "./src/app/modules/design-system/assets/styles/common.css",
              "./src/app/modules/design-system/assets/ui_plus/icons/webfonts/iconfonts-styles.css"
            ],
            "scripts": []
          }
        },
        "storybook-reactive-forms": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "src/app/modules/reactive-forms/.storybook",
            "browserTarget": "dynamic-site:build",
            "port": 6006,
            "compodoc": false
          }
        },
        "storybook-design-system": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "src/app/modules/design-system/.storybook",
            "browserTarget": "dynamic-site:build",
            "port": 6006,
            "compodoc": false
          }
        },
        "storybook-business-common": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "src/app/modules/business-common/.storybook",
            "browserTarget": "dynamic-site:build",
            "port": 6006,
            "compodoc": false
          }
        },
        "storybook-analytics": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "src/app/modules/analytics/.storybook",
            "browserTarget": "dynamic-site:build",
            "port": 6006,
            "compodoc": false
          }
        },
        "storybook-loyalty-progress": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "src/app/modules/loyalty-progress/.storybook",
            "browserTarget": "dynamic-site:build",
            "port": 6006,
            "compodoc": false
          }
        },
        "storybook-translation": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "src/app/modules/translation/.storybook",
            "browserTarget": "dynamic-site:build",
            "port": 6006,
            "compodoc": false
          }
        },
        "storybook-check-in-summary": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "src/app/modules/check-in-summary/.storybook",
            "browserTarget": "dynamic-site:build",
            "port": 6006,
            "compodoc": false
          }
        },
        "storybook-loyalty-overview-card": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "src/app/modules/loyalty-overview-card/.storybook",
            "browserTarget": "dynamic-site:build",
            "port": 6006,
            "compodoc": false
          }
        },
        "storybook-loyalty-status-overview": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "src/app/modules/loyalty-status-overview/.storybook",
            "browserTarget": "dynamic-site:build",
            "port": 6006,
            "compodoc": false
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "98fbcaee-0558-4d68-b128-d3408b01b05d"
  }
}
