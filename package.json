{
  "name": "dynamic-site",
  "version": "0.0.0",
  "main": "electron-launcher/main.js",
  "scripts": {
    "ng": "ng",
    "start:serve": "ng serve",
    "start:serve:bypass": "ng serve --configuration bypass",
    "start:proxy": "node --openssl-legacy-provider server/index-proxy.js",
    "start:sso-bypass": "node server/sso-bypass.js",
    "start:serve-proxy": "concurrently \"npm run start:serve\" \"npm run start:proxy\"",
    "start:serve-proxy-sso-bypass": "concurrently \"npm run start:serve:bypass\" \"node --openssl-legacy-provider server/index-proxy.js --sso-bypass-config\" \"npm run start:sso-bypass\"",
    "linux:enable-port-443": "bash ./enable-linux-port-443.sh",
    "build": "ng build",
    "build:compress": "node compress-dist.js",
    "build:prod": "ng build && node compress-dist.js",
    "start:backend": "node server/index.js",
    "start:backend:sso-bypass": "concurrently \"node server/index.js --sso-bypass-config\" \"npm run start:sso-bypass\"",
    "start:api": "node server/api.js",
    "launcher:open": "electron electron-launcher/main.js",
    "launcher:build:win": "electron-builder --win nsis",
    "launcher:build:mac": "electron-builder --mac dmg zip",
    "launcher:build:linux": "electron-builder --linux AppImage deb",
    "launcher:build:all": "electron-builder --win --mac --linux",
    "launcher:build:run": "node build-launcher-and-run.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "test-by-module": "electron electron-launcher/main.js --modal-only --by-module=tests",
    "storybook-by-module": "electron electron-launcher/main.js --modal-only --by-module=storybook",
    "test:watch": "ng test --browsers=ChromeHeadless",
    "lint": "eslint \"src/**/*.{ts,html}\"",
    "lint:styles": "stylelint \"src/**/*.{scss,css}\"",
    "styles:dev:sass": "sass --error-css --load-path=src/app/modules --style=expanded --embed-source-map src/app/modules/design-system/assets/sass:src/app/modules/design-system/assets/styles src/app/modules/design-system/assets/ui_plus/icons/webfonts/icomoon-styles.entry.scss:src/app/modules/design-system/assets/ui_plus/icons/webfonts/iconfonts-styles.css",
    "styles:dev:sass:watch": "sass --watch --error-css --load-path=src/app/modules --style=expanded --embed-source-map src/app/modules/design-system/assets/sass:src/app/modules/design-system/assets/styles src/app/modules/design-system/assets/ui_plus/icons/webfonts/icomoon-styles.entry.scss:src/app/modules/design-system/assets/ui_plus/icons/webfonts/iconfonts-styles.css",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json,md}\"",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o dist-storybook"
  },
  "scriptDescriptions": {
    "ng": "Executes Angular CLI directly.",
    "start:serve": "Starts Angular dev server with the default environment.",
    "start:serve:bypass": "Starts Angular dev server using the bypass environment (fake SSO setup).",
    "start:proxy": "Starts the local index/SEO proxy server on port 4300.",
    "start:sso-bypass": "Starts the fake local SSO/OIDC server on port 4500.",
    "start:serve-proxy": "Runs Angular dev server and proxy together.",
    "start:serve-proxy-sso-bypass": "Runs Angular bypass mode, proxy, and fake SSO together.",
    "linux:enable-port-443": "Enables Linux capability to bind port 443 without running the app as root.",
    "build": "Builds the Angular application for production.",
    "build:compress": "Pre-compresses the dist output with gzip and brotli (.gz / .br files alongside each original).",
    "build:prod": "Builds the Angular app for production and then pre-compresses the dist output.",
    "start:backend": "Starts the backend server entrypoint.",
    "start:backend:sso-bypass": "Runs backend in fake SSO mode together with the local fake SSO server.",
    "start:api": "Starts the booking flow API service on port 3000.",
    "launcher:open": "Opens the Electron launcher in development mode.",
    "launcher:build:win": "Builds the Windows launcher installer (NSIS).",
    "launcher:build:mac": "Builds the macOS launcher artifacts (DMG and ZIP).",
    "launcher:build:linux": "Builds Linux launcher artifacts (AppImage and DEB).",
    "launcher:build:all": "Builds launcher artifacts for Windows, macOS, and Linux.",
    "launcher:build:run": "Builds (or reuses) the launcher artifact for the current OS and runs it.",
    "watch": "Builds Angular in watch mode using the development configuration.",
    "test": "Runs unit tests once in headless Chrome.",
    "test-by-module": "Opens standalone by-module modal and runs unit tests for the selected module.",
    "storybook-by-module": "Opens standalone by-module modal and runs Storybook for the selected module.",
    "test:watch": "Runs unit tests in watch mode using headless Chrome.",
    "lint": "Runs ESLint on TypeScript and Angular HTML templates.",
    "lint:styles": "Runs Stylelint on SCSS and CSS source files.",
    "format": "Formats source files with Prettier."
  },
  "private": true,
  "build": {
    "appId": "com.flyr.dynamic.site.launcher",
    "productName": "Script launcher application",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-launcher/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron-launcher/main.js"
    },
    "win": {
      "icon": "electron-launcher/assets/launcher/windows/avianca-icon.png",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "electron-launcher/assets/launcher/mac/avianca-icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "electron-launcher/assets/launcher/linux/avianca-icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "desktop": {
        "Name": "Script launcher application",
        "StartupWMClass": "dynamic-site-launcher",
        "Icon": "avianca-icon"
      }
    }
  },
  "dependencies": {
    "@angular/animations": "19.2.14",
    "@angular/cdk": "19.2.19",
    "@angular/common": "19.2.14",
    "@angular/compiler": "19.2.14",
    "@angular/core": "19.2.14",
    "@angular/forms": "19.2.14",
    "@angular/localize": "^19.2.14",
    "@angular/platform-browser": "19.2.14",
    "@angular/platform-browser-dynamic": "19.2.14",
    "@angular/router": "19.2.14",
    "@flipt-io/flipt-client-js": "^0.0.5",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@ng-bootstrap/ng-bootstrap": "^18.0.0",
    "@ngrx/signals": "^19.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@popperjs/core": "^2.11.8",
    "angular-web-storage": "^17.0.0",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "dayjs": "^1.11.9",
    "flatpickr": "^4.6.13",
    "compression": "^1.8.1",
    "http-server": "^14.1.1",
    "keycloak-angular": "^16.1.0",
    "keycloak-js": "^25.0.6",
    "localforage": "^1.10.0",
    "ngx-cookie": "^6.0.1",
    "ngx-skeleton-loader": "^9.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.1902.14",
    "@angular-devkit/build-angular": "19.2.17",
    "@angular-eslint/eslint-plugin": "^18.3.1",
    "@angular-eslint/eslint-plugin-template": "^18.3.1",
    "@angular-eslint/template-parser": "^18.3.1",
    "@angular/cli": "19.2.14",
    "@angular/compiler-cli": "19.2.14",
    "@chromatic-com/storybook": "^3.2.5",
    "@compodoc/compodoc": "1.1.24",
    "@storybook/addon-a11y": "^8.6.2",
    "@storybook/addon-essentials": "^8.6.2",
    "@storybook/addon-interactions": "^8.6.2",
    "@storybook/addon-links": "^8.6.2",
    "@storybook/addon-themes": "^8.6.4",
    "@storybook/angular": "^8.6.2",
    "@storybook/blocks": "^8.6.2",
    "@storybook/core-server": "^8.6.2",
    "@storybook/test": "^8.6.2",
    "@types/jasmine": "~5.1.0",
    "@types/ua-parser-js": "^0.7.36",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.9.0",
    "concurrently": "8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^25.0.5",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-perfectionist": "^3.8.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.3.3",
    "sass": "^1.98.0",
    "storybook": "^8.6.17",
    "storybook-dark-mode": "^4.0.2",
    "stylelint": "^16.9.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-prettier": "^5.0.2",
    "stylelint-scss": "^6.8.1",
    "typescript": "5.6.3"
  }
}
