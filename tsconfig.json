/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "baseUrl": ".",
    "paths": {
      "@navigation": ["src/app/modules/navigation/index.ts"],
      "@dynamic-composite": ["src/app/modules/dynamic-composite/index.ts"],
      "@dcx/ui/api-layer": ["src/app/modules/api-layer/src/public-api.ts"],
      "@dcx/ui/business-common": ["src/app/modules/business-common/src/public-api.ts"],
      "@dcx/ui/libs": ["src/app/modules/libs/src/public-api.ts"],
      "@dcx/ui/design-system": ["src/app/modules/design-system/index.ts"],
      "@dcx/ui/storybook-utils": ["src/app/modules/design-system/.storybook/utils/index.ts"],
      "@dcx/storybook/design-system": ["src/app/modules/storybook-design-system/index.ts"],
      "@dcx/module/translation": ["src/app/modules/translation/src/public-api.ts"],
      "@dcx/ui/mock-repository": ["src/app/modules/mock-repository/index.ts"],
      "@reactive-forms": ["src/app/modules/reactive-forms/src/lib/index.ts"],
      "reactive-forms": ["src/app/modules/reactive-forms/src/public-api.ts"],
      "@fake-blocks-test": ["src/app/modules/fake-blocks-test/index.ts"],
      "@fake-blocks-avianca": ["src/app/modules/fake-blocks-avianca/index.ts"],
      "fake-libs": ["src/app/modules/fake-libs/index.ts"],
      "@games": ["src/app/modules/games/index.ts"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
